<% if (theme.plugins.swiper) { %>
    <script>
        const swiper_api = document.getElementById('swiper-api');
        if (swiper_api != undefined) {
            stellar.loadCSS(stellar.GLOBAL_CONFIG.plugins.swiper.css);
            stellar.loadScript(stellar.GLOBAL_CONFIG.plugins.swiper.js, { defer: true }).then(function () {
                const effect = swiper_api.getAttribute('effect') || '';
                var swiper = new Swiper('.swiper#swiper-api', {
                slidesPerView: 'auto',
                spaceBetween: 8,
                centeredSlides: true,
                effect: effect,
                loop: true,
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
                });
            })
        }
    </script>
<% } %>