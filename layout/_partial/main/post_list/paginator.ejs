<% if ((is_home() || is_category() || is_tag()) && page.total > 1) { %>
  <div class='paginator-wrap dis-select'>
  <%- paginator({
    prev_text: "<i class='fa-duotone fa-angles-left fa-fw'></i>",
    next_text: "<i class='fa-duotone fa-angles-right fa-fw'></i>",
    force_prev_next:true,
    escape: false
  }) %>
  </div>
<% } %>
