set_mermaid_darkmode()
set_darkmode_comments()
set_darkmode_tags()

.wl-count
    padding: .375em
    font-weight: bold
    font-size: 1.25em
    color: #ddd

.float-panel
    --blur-bg: alpha(#000, .4)
.social-wrap
    a.social
        &:hover
            box-shadow: none

img
    filter: brightness(75%)!important

.iziToast
    .iziToast-close
        background: url('data:image/png;base64,') no-repeat 50% 50%
        background-size: 8px

ul.list-v
    box-shadow: $boxshadow-card-float

.timenode .highlight .code-tools
    background: #222529
