ul.list-v
  z-index: 1
  display: none
  &.show
    display: block
  position: absolute
  background: var(--block)
  // box-shadow: $boxshadow-card-float
  box-shadow: $boxshadow-dropmenu
  margin-top: -2px - $border-block * 0.5
  border-radius: $border-block
  padding: $gap * 0.5 0
  hr
    margin-top: $gap * 0.5
    margin-bottom: $gap * 0.5
  >li
    white-space: nowrap
    word-break: keep-all
    &.header
      font-size: $fs-12
      font-weight: bold
      line-height: 2em
      color: var(--text-meta)
      margin: $gap * 0.5 $gap $gap * 0.25
      i
        margin-right: 8px
    ul
      margin-left: 0
      display: none
      margin-top: 0 - 32px - $gap * 0.5
  .aplayer-container
    min-height: 64px
    padding: $gap - 10px $gap
  >li>a
    transition: all 0.28s ease
    display: block
    color: var(--text-p3)
    font-size: $fs-15
    // font-weight: bold
    line-height: 36px
    @media screen and (max-width: $device-laptop)
      line-height: 40px
    padding: 0 $gap + 4px 0 $gap
    text-overflow: ellipsis
    margin: 0 4px
    border-radius: 4px
    >i
      margin-right: 8px
    &:active,&.active
      color: $color-hover
    &:hover
      color: $color-hover
      background: var(--site-bg)

div#rightmenu-wrapper
  display: none
  position:fixed
  z-index: 2147483648
  disable-user-select()

ul.list-v.rightmenu
  display: block
  max-width: 240px
  min-width: 170px
  overflow: hidden
  &.left
    right: 0
  &.top
    bottom: 0
  $cellH = 32px
  a
    cursor: default
  a.vlts-menu
    text-overflow: ellipsis
    overflow: hidden
    line-height: $cellH
    font-weight: normal
  >li>span
    cursor: default
    transition: all 0.28s ease
    display: block
    color: var(--text-p3)
    font-size: $fs-15
    // font-weight: bold
    line-height: 36px
    @media screen and (max-width: $device-laptop)
      line-height: 40px
    padding: 0 $gap + $border-line + 2px 0 $gap
    text-overflow: ellipsis
    margin: 0 4px
    border-radius: 4px
    >i
      margin-right: 8px
    &:active,&.active
      color: $color-hover
    &:hover
      color: $color-hover
      background: var(--site-bg)
  li.navigation, li.music
    display: flex
    justify-content: space-between
    a.icon-only
      line-height: 0
      margin: 0
      padding: 0
      border-radius: $cellH
      overflow: hidden
      width: $cellH
      height: $cellH
    a.nav
      i
        margin: 0
        width: $cellH
        line-height: $cellH
      &:first-child
        margin-left: 2px + $gap * 0.5
      &:last-child
        margin-right: 2px + $gap * 0.5
  li.music
    &.name
      display: flex
      flex-direction: column
      align-items: center
      p.nav.music-title
        color: var(--text-p3)
        font-size: $fs-15
        font-weight: 600
        max-width: 128px
        margin: 0 4px + $gap
        overflow: hidden
        &:hover
          background: none
    .nav.volume
      width: 100%
      padding: 0 $gap * 0.5
      &:hover
        background: transparent
      .aplayer-volume-bar
        margin: $gap * 0.25 0 $gap * 0.5
        position: relative
        height: 8px
        width: 100%
        background: $color-block
        border-radius: $cellH
        overflow: hidden
        cursor: $pointer
        i.left, i.right
          color: var(--text-p3)
          position: absolute
          top: 0
          width: $cellH - 4px
          line-height: $cellH - 4px
          transition: all 0.28s ease
          opacity: 0
          transform: scale(0.5) translateY(-0.5 * $cellH - 2px)
        i.left
          left: 0
        i.right
          right: 0
        transition: all 0.28s ease
        &:hover
          height: $cellH - 4px
          i
            opacity: 1
            transform: scale(1) translateY(0)
        .aplayer-volume
          background: $color-theme
          height: 100%
          width: 100%

