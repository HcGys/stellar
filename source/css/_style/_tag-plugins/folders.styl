.tag-plugin.folders
  margin: var(--gap-p) 0
  font-size: $fs-14
  border-top: 1px solid var(--block-border)
  overflow: hidden
  .folder
    border-bottom: 1px solid var(--block-border)
    padding: 1rem
    >details>summary
      cursor: pointer
      color: var(--text-p2)
      font-weight: 500
      position: relative
      line-height: 1.2
      outline: none
      padding: 1rem
      margin: -1rem
      &:last-child
        border-bottom: none
      >
        span 
          margin-left: 0.25em
        p,h1,h2,h3,h4,h5,h6
          display: inline
          border-bottom: none !important
      &:hover
        color: var(--text-p0)
      &:after
        position: absolute
        content: '+'
        text-align: center
        top: 50%
        transform: translateY(-50%)
        right: 1rem
    >div.body  // 一定要加>,否则会将所有的递归子div.body除掉。这里只需要除掉第一层的div.body
      display: none


.tag-plugin.folders details[open]
  >summary
    color: var(--text-p1)
    font-weight: 700
    &:after
      content: '-'
      
  +div.body
    display: block
    font-size: $fs-15
    >:first-child
      margin-top: 1rem
    >:last-child
      margin-bottom: 0