.md-text .tag-plugin.paper
  display: flex
  flex-direction: column
  align-items: center
  .content
    border-left: 1px dashed var(--block-border)
    border-right: 1px dashed var(--block-border)
    border-bottom: 1px dashed var(--block-border)
    border-bottom-left-radius: 8px
    border-bottom-right-radius: 8px
    padding: 1rem
    // max-width: calc(100% - 80px)
    max-width: calc(95%)
    >.title
      font-weight: 500
      font-size: 1rem
      text-align: center
    >.meta
      color: var(--text-p2)
      font-size: $fs-12
      font-weight: 500  
    >.body
      font-size: $fs-14
      >.paragraph
        text-indent: 2em
      >.section
        >.section-title
          text-align: center
        >.section-content
          text-indent: 2em
      >.line.right
        >p
          text-align: right
    >.footer
      color: var(--text-p4)
      font-size: $fs-12
      text-align: right
      >.author-date
        color: var(--text-p2)
        font-size: $fs-12
        font-weight: 500
        text-align: right
        >.author
          margin-right: var(--gap-p)

// 描边修饰
.md-text .tag-plugin.paper .content
  position: relative
  &:before
    content: ''
    position: absolute
    height: 4px
    left: -16px
    top: -4px
    right: -16px
    border-radius: 4px
    background: var(--block)
  >.title
    position: relative
    &:before
      content: ''
      position: absolute
      height: 4px
      left: calc(-1rem - 6px)
      top: calc(-1rem - 4px)
      right: calc(100% + 1rem - 6px)
      border-radius: 4px
      background: $color-accent
    &:after
      content: ''
      position: absolute
      height: 4px
      right: calc(-1rem - 6px)
      top: calc(-1rem - 4px)
      left: calc(100% + 1rem - 6px)
      border-radius: 4px
      background: $color-accent

// 下划线修饰
.md-text .tag-plugin.paper > .content.line > .title,
.md-text .tag-plugin.paper > .content.line > .meta,
.md-text .tag-plugin.paper > .content.line > .author-date,
.md-text .tag-plugin.paper > .content.line > .footer,
.md-text .tag-plugin.paper > .content.line > .body 
  background: linear-gradient(var(--site-bg) 1.5rem,var(--block-border) 1px)
  background-size: 100% calc(1.5rem + 1px)
  line-height: calc(1.5rem + 1px)

.md-text .tag-plugin.paper > .content.line p
  margin: 0
