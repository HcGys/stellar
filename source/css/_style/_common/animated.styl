// 从 https://blog.imsyy.top/ 扒下来的动画

.tab-pane
  animation: fade-in
  animation-duration: 0.3s
  -webkit-animation: fade-in 0.3s

div.tabs ul.nav-tabs li.tab.active a
  transition: 0.5s

div.tabs .tab-content .tab-pane.active
  animation: tabshow 0.2s cubic-bezier(0.23, 0, 0, 1.32)
  -moz-animation: tabshow 0.2s cubic-bezier(0.23, 0, 0, 1.32)
  -o-animation: tabshow 0.2s cubic-bezier(0.23, 0, 0, 1.32)
  -ms-animation: tabshow 0.2s cubic-bezier(0.23, 0, 0, 1.32)
  -webkit-animation: tabshow 0.2s cubic-bezier(0.23, 0, 0, 1.32)

ul.list-v.rightmenu
  animation: header-effect 0.2s cubic-bezier(0.23, 0, 0, 1.32)
  -moz-animation: header-effect 0.2s cubic-bezier(0.23, 0, 0, 1.32)
  -o-animation: header-effect 0.2s cubic-bezier(0.23, 0, 0, 1.32)
  -ms-animation: header-effect 0.2s cubic-bezier(0.23, 0, 0, 1.32)
  -webkit-animation: header-effect 0.2s cubic-bezier(0.23, 0, 0, 1.32)

.container ul.list-v
  animation: sub_menus
  animation-duration: 0.3s
  -webkit-animation: sub_menus 0.3s

// details summary:hover
//   transition: 0.3s

details[open] + div.body
  -webkit-animation: header-effect 0.3s cubic-bezier(0.68, -0.55, 0.27, 1.55)
  -moz-animation: header-effect 0.3s cubic-bezier(0.68, -0.55, 0.27, 1.55)
  -o-animation: header-effect 0.3s cubic-bezier(0.68, -0.55, 0.27, 1.55)
  -ms-animation: header-effect 0.3s cubic-bezier(0.68, -0.55, 0.27, 1.55)
  animation: header-effect 0.3s cubic-bezier(0.68, -0.55, 0.27, 1.55)

#prev:hover > .note > i,
.wiki-home.cap:hover > svg,
.wiki-home.cap:hover > i
    animation: lr .3s ease-in 0s infinite alternate

#next:hover > .note > i 
    animation: rl .3s ease-in 0s infinite alternate


#u-search
  .modal
    -webkit-transition: .3s
    -moz-transition: .3s
    -o-transition: .3s
    -ms-transition: .3s
    transition: .3s

.highlight.fullscreen
  transition: .3s
  animation: slide-in .6s ease 0s 1 normal none running

