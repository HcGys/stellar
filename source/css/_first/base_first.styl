:root
  --site-bg: hsl($color-background-h, $color-background-s, $color-background-l)
  --card: hsl($color-block-h, $color-block-s, 100)
  --block: hsl($color-block-h, $color-block-s, 95)
  --block-border: hsl($color-block-h, $color-block-s, 90)
  --block-hover: hsl($color-block-h, $color-block-s, 92)
  --img-error-bg: #f3f3f3
  --img-error-text-bg: #e3e5e5
  --search-blur-bg: #e9eff180 //rgb(233 239 241 / 50%)
  --code-tools: #dfe0e3
  set_text_dark()
  --theme-bg2: $color-theme
  --theme-link: $color-link

*
  outline: none
body *
  scrollbar-codeblock()
html
  font-family: $ff-body
  font-size: $fs-root
  -webkit-text-size-adjust: 100%
  -ms-text-size-adjust: 100%
  if hexo-config('style.smooth_scroll')
    scroll-behavior: smooth
  if hexo-config('style.scrollbar.size')
    scrollbar(convert(hexo-config('style.scrollbar.size')), convert(hexo-config('style.scrollbar.border')) || 0px, convert(hexo-config('style.scrollbar.color')) || var(--text-meta), convert(hexo-config('style.scrollbar.hover')) || var(--text-p3))

body
  background: var(--site-bg)
  margin: 0
  -webkit-font-smoothing: antialiased
  -moz-osx-font-smoothing: grayscale
  text-rendering: optimizelegibility
  -webkit-tap-highlight-color: rgba(0, 0, 0, 0)

.fullscreen
  position: fixed !important
  top: 0  !important
  left: 0 !important
  width: 100% !important
  height: 100%  !important
  min-width: 100% !important
  z-index: 9  !important
  margin: 0 !important
  border-radius: 0  !important

article.md-text
  transform: unset !important
